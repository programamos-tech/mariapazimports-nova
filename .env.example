# =============================================================================
# VARIABLES DE ENTORNO — referencia para Vercel y desarrollo local
# Todas las de Supabase deben ser del MISMO proyecto (mismo ref en la URL).
# En Vercel: Settings → Environment Variables. Tras cambiar NEXT_PUBLIC_* o
# SUPABASE_*, hacé un redeploy para que el cliente y el middleware tomen valores.
# =============================================================================

# -----------------------------------------------------------------------------
# OBLIGATORIAS EN PRODUCCIÓN (Vercel)
# -----------------------------------------------------------------------------
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Solo servidor (Server Actions, scripts). Nunca en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública del sitio (sin barra final). Wompi redirects y enlaces absolutos.
# Ej.: https://mariapazimports.vercel.app o https://tudominio.com
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# -----------------------------------------------------------------------------
# WOMPI — obligatorias si querés cobro real / link de pago (no solo modo dev)
# -----------------------------------------------------------------------------
# sandbox | production
WOMPI_ENV=sandbox
WOMPI_PRIVATE_KEY=prv_test_...
# Opcional: firma de integridad del webhook (si falla, dejalo vacío y revisá docs Wompi)
WOMPI_INTEGRITY_SECRET=

# En desarrollo: sin WOMPI_PRIVATE_KEY el checkout puede omitir Wompi.
# CHECKOUT_SKIP_WOMPI=1

# -----------------------------------------------------------------------------
# OPCIONALES — marca, contacto y textos (si no van, el código usa defaults en lib/brand.ts)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STORE_NAME=María Paz Importaciones
NEXT_PUBLIC_STORE_COPYRIGHT_NAME=María Paz Importaciones
NEXT_PUBLIC_STORE_TAGLINE=Personal Shopper · Productos 100% originales
NEXT_PUBLIC_STORE_DESCRIPTION=Importaciones seleccionadas con asesoría personalizada.
NEXT_PUBLIC_STORE_PHONE=+57 300 555 0100
NEXT_PUBLIC_STORE_EMAIL=hola@mariapazimports.com
NEXT_PUBLIC_STORE_HOURS=Lun. a vie. · 9:00 – 18:00 (Colombia)
NEXT_PUBLIC_STORE_INSTAGRAM_URL=https://www.instagram.com/mariapazimports/
NEXT_PUBLIC_STORE_ANNOUNCEMENT=Productos 100% originales — envíos nacionales
NEXT_PUBLIC_STORE_WELCOME_BANNER=Bienvenida: 10% OFF en tu primera compra
NEXT_PUBLIC_STORE_WELCOME_CODE=BIENVENIDA10
NEXT_PUBLIC_WHATSAPP_NUMBER=573005550100
NEXT_PUBLIC_WHATSAPP_TEXT=Hola, quiero asesoría para elegir mis productos.

# Fotos de ejemplo (Unsplash) cuando un producto no tiene image_path.
# Desarrollo: activo por defecto. Desactivar con 0. Producción: solo con 1.
# NEXT_PUBLIC_DEMO_PRODUCT_IMAGES=0

# Login admin: correo sugerido en el campo (opcional)
NEXT_PUBLIC_PLATFORM_EMAIL=mp@imports.com

# Panel admin — titular visible (sidebar). Email visible cae a PLATFORM_EMAIL si no va.
NEXT_PUBLIC_ADMIN_OWNER_NAME=María Paz
NEXT_PUBLIC_ADMIN_OWNER_EMAIL=mp@imports.com
# Opcional: semilla fija para el avatar DiceBear
# NEXT_PUBLIC_ADMIN_OWNER_AVATAR_SEED=

# -----------------------------------------------------------------------------
# SOLO LOCAL / SCRIPTS (no hace falta en Vercel salvo que corras jobs en Vercel)
# -----------------------------------------------------------------------------
# SEED_STOCK_LOCAL=100
# SEED_STOCK_WAREHOUSE=0
# SEED_PRODUCT_PHOTOS_DIR=product-photos
# SUPABASE_PROJECT_REF=abcd1234   # alternativa a supabase/.temp/project-ref

# Archivo opcional en la raíz: URL + service role de OTRO proyecto (sobrescribe .env.local en scripts)
# .env.cloud

# -----------------------------------------------------------------------------
# Comandos útiles (misma URL que arriba; supabase link al proyecto)
# -----------------------------------------------------------------------------
# npm run seed:produtos:remote
# npm run admin:ensure:remote -- correo@dominio.com contraseña
# npm run admin:ensure:remote -- --reset correo@dominio.com contraseña
