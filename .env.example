# Supabase (proyecto por cliente / fork)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo servidor — nunca expongas esto al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Opcional: seed del Excel hacia OTRO proyecto (nube) sin tocar .env.local.
# Copia aquí URL + service role remotos; el script seed-produtos-xlsx los aplica
# después de .env.local (sobrescribe).
# Archivo: .env.cloud (no commitear; está en .gitignore con .env*)
#
# Fotos de producto al seed: carpeta product-photos/ con 1.jpg, 2.png… según columna NUMERO FOTO
#   SEED_PRODUCT_PHOTOS_DIR=product-photos
#
# O, con CLI y `supabase link`: npm run seed:produtos:remote

# URL pública del sitio (Vercel: https://tu-dominio.com) — usada en redirect Wompi
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nombre visible en la tienda (default en código: programamos templates)
NEXT_PUBLIC_STORE_NAME=programamos templates
# Opcional — footer y barra superior
# NEXT_PUBLIC_STORE_PHONE=+57 (1) 234 5678
# NEXT_PUBLIC_STORE_EMAIL=hola@tutienda.com

# Wompi Colombia — usar claves test o prod según WOMPI_ENV
WOMPI_ENV=sandbox
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_PUBLIC_KEY=pub_test_...
# Opcional: validación de firma de webhooks (si falla, revisá docs Wompi o dejalo vacío en dev)
WOMPI_INTEGRITY_SECRET=
